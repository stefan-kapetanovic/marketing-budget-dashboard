    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // Konfiguracija i podaci
            const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'Maj', 'Jun', 'Jul', 'Avg', 'Sep', 'Okt', 'Nov', 'Dec'];
            
            // Podaci (u milionima dinara, realistični za dobar salon)
            const data2025 = [2.2, 2.4, 2.8, 3.1, 3.5, 3.8, 3.2, 2.9, 3.4, 3.1, 2.5, 3.0];
            const data2026 = [2.8, 3.1, 3.5, 3.9, 4.2, 4.5, 4.0, 3.6, 4.1, 3.8, 3.2, 4.3]; // Skok u decembru zbog praznika

            // Dizajn tokeni iz Tailwinda
            const colorBrand = '#fb7185'; // rose-400
            const colorBrandLight = 'rgba(251, 113, 133, 0.15)'; // rose-400 sa providnošću
            const colorGray = '#d4d4d8'; // zinc-300
            const fontSans = "'Poppins', sans-serif";

            // --- 1. Glavni Grafikon (Zakrivljena linija - Spline Chart) ---
            Chart.defaults.font.family = fontSans;
            Chart.defaults.color = '#71717a';

            const ctxLine = document.getElementById('revenueSplineChart').getContext('2d');
            
            // Kreiramo gradijent za popunjavanje ispod linije (lep beauty efekat)
            const gradient = ctxLine.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, colorBrandLight);
            gradient.addColorStop(1, 'rgba(255,255,255,0)');

            const lineChart = new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Prihod 2026 (Milioni RSD)',
                            data: data2026,
                            borderColor: colorBrand,
                            backgroundColor: gradient,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4, // Ovo pravi "spline" (zakrivljenu) liniju umesto oštre
                            pointBackgroundColor: '#fff',
                            pointBorderColor: colorBrand,
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Prihod 2025 (Milioni RSD)',
                            data: data2025,
                            borderColor: colorGray,
                            borderWidth: 2,
                            borderDash: [5, 5], // Isprekidana linija za prošlu godinu
                            fill: false,
                            tension: 0.4,
                            pointRadius: 0, // Sakrijemo tačke za prošlu godinu da ne guše prikaz
                            pointHoverRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: { display: false }, // Legenda je napravljena custom u HTML-u
                        tooltip: {
                            backgroundColor: 'rgba(255, 255, 255, 0.95)',
                            titleColor: '#27272a',
                            bodyColor: '#52525b',
                            borderColor: '#fecdd3',
                            borderWidth: 1,
                            padding: 12,
                            boxPadding: 6,
                            usePointStyle: true,
                            callbacks: {
                                label: function(context) {
                                    return ` ${context.dataset.label.split(' ')[1]}: ${context.parsed.y}M rsd`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f4f4f5',
                                drawBorder: false,
                            },
                            ticks: {
                                callback: function(value) { return value + 'M'; },
                                padding: 10
                            }
                        },
                        x: {
                            grid: {
                                display: false,
                                drawBorder: false
                            },
                            ticks: { padding: 10 }
                        }
                    }
                }
            });

            // --- 2. Doughnut Grafikon (Usluge) ---
            const ctxDoughnut = document.getElementById('servicesChart').getContext('2d');
            new Chart(ctxDoughnut, {
                type: 'doughnut',
                data: {
                    labels: ['Tretmani Lica', 'Masaže & Telo', 'Kozmetika'],
                    datasets: [{
                        data: [45, 30, 25],
                        backgroundColor: [
                            '#fb7185', // rose-400
                            '#fecdd3', // rose-200
                            '#a5b4fc', // indigo-300
                        ],
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%', // Tanka linija, moderan izgled
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#27272a',
                            padding: 10,
                            callbacks: {
                                label: function(context) { return ` ${context.label}: ${context.parsed}%`; }
                            }
                        }
                    }
                }
            });

            // --- 3. Logika Interaktivnog Slajdera ---
            const slider = document.getElementById('monthSlider');
            const monthLabel = document.getElementById('monthRangeLabel');

            slider.addEventListener('input', function() {
                const monthsToShow = parseInt(this.value);
                
                // Formatiranje teksta u headeru
                if (monthsToShow === 1) {
                    monthLabel.textContent = "Samo Januar";
                } else {
                    monthLabel.textContent = `Januar - ${labels[monthsToShow - 1]}`;
                }

                // Dinamičko sečenje (slice) nizova na osnovu slajdera
                lineChart.data.labels = labels.slice(0, monthsToShow);
                lineChart.data.datasets[0].data = data2026.slice(0, monthsToShow);
                lineChart.data.datasets[1].data = data2025.slice(0, monthsToShow);
                
                // Ugrađena animacija Chart.js pri update-u
                lineChart.update();
            });
        });
    </script>
</body>
</html>
